class GFG {
    static void rotate(int m[][]) {
        // Code Here
        int n = m.length - 1;
        
        for(int i=0; i<(n+2)/2; i++){
            for(int j=0; j<(n+1)/2; j++){
                int t = m[n-j][i];
                m[n-j][i] = m[n-i][n-j];
                m[n-i][n-j] = m[j][n-i];
                m[j][n-i] = m[i][j];
                m[i][j] = t;
            }
        }
    }
}
