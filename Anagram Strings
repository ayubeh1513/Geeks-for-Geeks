// User function template for Java
class Solution {
    static int areAnagram(String S1, String S2) {
        // code here
        int a=0, b=0;
        for(char i : S1.toCharArray()){
            a += (int) i;
        }
        for(char i : S2.toCharArray()){
            b += (int) i;
        }
        
        if(a==b) return 1;
        return 0;
    }
}
