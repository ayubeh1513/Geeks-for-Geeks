class Solution {
    void pushZerosToEnd(int[] arr) {
        // code here
        int z=0;
        int k=0;
        for(int i : arr){
            if(i != 0){
                arr[k]=i;
                k++;
            } else{
                z++;
            }
        }
        
        for(int i=0; i<z; i++){
            arr[k]=0;
            k++;
        }
    }
}
