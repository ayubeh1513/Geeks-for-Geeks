class Solution {
    public boolean canSplit(int arr[]) {
        int totalSum = 0;

        for (int num : arr) {
            totalSum += num;
        }

        if (totalSum % 2 != 0) {
            return false;
        }

        int prefixSum = 0;

        for (int i = 0; i < arr.length; i++) {
            prefixSum += arr[i];

            if (prefixSum == totalSum / 2) {
                return true;
            }
        }

        return false;
    }
}
