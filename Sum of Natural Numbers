import java.util.Scanner;

class GFG {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        int n = sc.nextInt();

        // code here
        System.out.print(pS(n));
    }
    
    public static int pS(int n){
        if(n==0) return 0;
        return n + pS(n-1);
    }
}
