class Solution {

    public static boolean isPanagram(String str) {
        // Your code here
        int[] a = new int[26];
        for(int i=0; i<26; i++){
            a[i]=0;
        }
        
        str = str.toLowerCase();
        for(char i : str.toCharArray()){
            a[i-'a']+=1;
        }
        
        for(int i : a){
            if(i<1) return false;
        }
        
        return true;
    }
}
