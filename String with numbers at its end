class Solution {
    int isSame(String s) {
        // code here
        long n=0;
        int a=0;
        for(char i : s.toCharArray()){
            if((i>='a' && i<='z') || (i>='A' && i<='Z')){
                a++;
            } else{
                n *= 10;
                n += (i-'0');
            }
        }
        
        if(n==a) return 1;
        return 0;
    }
}
