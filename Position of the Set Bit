class Solution {
    public int findPosition(int n) {
        // code here
        int a = -1;
        int i = 1;
        while(n>0){
            if(n%2==1){
                a=i;
                n/=2;
                break;
            }
            
            n/=2;
            i++;
        }
        
        while(n>0){
            if(n%2==1) return -1;
            n/=2;
        }
        
        return a;
    }
}
