class Solution {
    public int romanToDecimal(String s) {
        // code here
        int r=0;
        for(int i=0; i<s.length(); i++){
            if((i+1)<s.length() && gV(s.charAt(i))<gV(s.charAt(i+1))){
                r -= gV(s.charAt(i));
            } else {
                r += gV(s.charAt(i));
            }
        }
        
        return r;
    }
    
    public int gV(char a){
        switch(a){
            case 'I':
                return 1;
            case 'V':
                return 5;
            case 'X':
                return 10;
            case 'L':
                return 50;
            case 'C':
                return 100;
            case 'D':
                return 500;
            case 'M':
                return 1000;
        }
        
        return -1;
    }
}
