class Solution {
    public int countIncreasing(int[] arr) {
        // code here
        int r=0;
        for(int i=0; i<arr.length-1; i++){
            int a=0;
            int b=i;
            int c=i+1;
            while(a==0 && c<arr.length){
                if(arr[b]<arr[c]){
                    b++;
                    c++;
                    r++;
                } else{
                    a=1;
                }
            }
        }
        return r;
    }
}
